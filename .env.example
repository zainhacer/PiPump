# ─── Supabase ───────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Pi Network ─────────────────────────────────────────
# Pi App name from Pi Developer Portal
VITE_PI_APP_NAME=pipump
# Sandbox mode for testnet (true = testnet, false = mainnet)
VITE_PI_SANDBOX=true

# ─── Platform Wallet ────────────────────────────────────
# Your Pi wallet address — receives creation fees & trade fees
VITE_PLATFORM_WALLET_ADDRESS=your-pi-wallet-address-here

# ─── Admin ──────────────────────────────────────────────
# Comma-separated Pi UIDs who have admin access
VITE_ADMIN_UIDS=admin-pi-uid-here

# ─── App Config ─────────────────────────────────────────
# Token creation fee in Pi
VITE_CREATION_FEE=1
# Trade fee percentage (1 = 1%)
VITE_TRADE_FEE_PERCENT=1
# Graduation threshold in real Pi collected
VITE_GRADUATION_THRESHOLD=800
# Base URL for GitHub Pages
VITE_BASE_URL=/pipump/
